OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
MAIL_PROVIDER=google_api
AGENT_EMAIL=your-agent@gmail.com
SENDER_POLICY_MODE=all
ALLOWED_SENDERS=
POLL_SECONDS=20
STATE_DB=./state.db
GOOGLE_TOKEN_FILE=./token.json
GOOGLE_CREDENTIALS_FILE=./credentials.json
GOOGLE_DRIVE_DEFAULT_FOLDER_ID=
GOG_ACCOUNT=
GOG_GMAIL_TOPIC=
GOG_GMAIL_LABEL=INBOX
GOG_GMAIL_HOOK_TOKEN=
GOG_GMAIL_PUSH_TOKEN=
GOG_GMAIL_HOOK_URL=http://127.0.0.1:8787/hooks/gmail
GOG_GMAIL_SERVE_BIND=127.0.0.1
GOG_GMAIL_SERVE_PORT=8788
GOG_GMAIL_SERVE_PATH=/gmail-pubsub
GOG_GMAIL_SUBSCRIPTION=gog-gmail-watch-push
GOG_GMAIL_PUSH_ENDPOINT=
GOG_GMAIL_INCLUDE_BODY=true
GOG_GMAIL_MAX_BYTES=20000
GOG_GMAIL_RENEW_EVERY_MINUTES=720
SYSTEM_PROMPT_FILE=./SYSTEM_PROMPT.md
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=800
RETRY_MAX_DELAY_MS=8000
RETRY_JITTER_MS=250
